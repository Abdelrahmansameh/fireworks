{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:5500",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:///./src/*": "${webRoot}/*"
            }
        },
        {
            "name": "Run Bonesmith (Script)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/tools/bonesmith/run_bonesmith.py",
            "console": "integratedTerminal",
            "args": []
        }
    ]
}
